<!-- 孤立问题页面 -->
<view class="page-container">
  <!-- 头部 -->
  <view class="header">
    <view class="tab-title">孤立问题</view>
    <view class="refresh-btn" bindtap="refreshData">
      <text class="icon-refresh {{isRefreshing ? 'rotating' : ''}}">↻</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{isLoading}}" class="loading-container">
    <loading></loading>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 错误状态 -->
  <view wx:elif="{{hasError}}" class="error-container">
    <text class="error-icon">⚠</text>
    <text class="error-text">{{errorMessage}}</text>
    <view class="retry-button" bindtap="refreshData">重试</view>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{isEmpty}}" class="empty-container">
    <text class="empty-icon">📥</text>
    <text class="empty-text">暂无孤立的问题</text>
    <text class="empty-desc">孤立问题是指还未被归类到主要结构中的问题文档</text>
  </view>

  <!-- 孤立问题列表 -->
  <scroll-view wx:else class="tree-container" scroll-y="true" enhanced="true" show-scrollbar="false">
    <view wx:for="{{orphanedData}}" wx:key="id" class="list-item" bindtap="onSelectNode" data-node="{{item}}">
      <view class="list-item-icon">📄</view>
      <view class="list-item-content">
        <view class="list-item-title">{{item.title}}</view>
        <view class="list-item-path">{{item.filePath}}</view>
      </view>
      <view class="list-item-arrow">›</view>
    </view>
  </scroll-view>
</view>
