/* 详情页样式 */
.page-container {
  height: 100vh;
  background-color: #ffffff;
}

.content-container {
  height: 100vh;
  padding: 0 40rpx;
}

/* 文章头部 */
.article-header {
  padding: 40rpx 0;
  border-bottom: 1rpx solid #e9ecef;
  margin-bottom: 40rpx;
}

.article-title {
  font-size: 42rpx;
  font-weight: bold;
  color: #212529;
  line-height: 1.4;
  display: block;
  margin-bottom: 20rpx;
}

.article-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.meta-item {
  font-size: 24rpx;
  color: #6c757d;
  padding: 8rpx 16rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
}

.article-path {
  display: flex;
  align-items: center;
  padding: 12rpx 16rpx;
  background-color: #f8f9fa;
  border-radius: 8rpx;
  margin-top: 12rpx;
}

.path-icon {
  font-size: 24rpx;
  margin-right: 12rpx;
}

.path-text {
  font-size: 22rpx;
  color: #6c757d;
  font-family: 'Monaco', 'Consolas', monospace;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.article-path:active {
  background-color: #e9ecef;
}

/* Markdown内容 */
.markdown-content {
  line-height: 1.8;
  color: #212529;
  font-size: 30rpx;
  word-break: break-word;
  padding-bottom: 180rpx; /* 为FAB组留出空间 */
}

.markdown-text {
  white-space: pre-wrap;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
  display: block;
}

/* 浮动操作按钮组 */
.fab-container {
  position: fixed;
  right: 40rpx;
  bottom: 40rpx;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.fab-primary, .fab-secondary {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s ease;
}

.fab-primary {
  background-color: #007aff;
}

.fab-secondary {
  background-color: #ffffff;
  border: 2rpx solid #e9ecef;
}

.fab-primary:active, .fab-secondary:active {
  transform: scale(0.95);
}

.fab-primary .fab-icon {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: bold;
}

.fab-secondary .fab-icon {
  font-size: 32rpx;
  color: #6c757d;
}

/* 状态页面样式继承全局样式 */
.error-container {
  height: 100vh;
}

/* 响应式优化 */
@media screen and (max-width: 600rpx) {
  .article-header {
    padding: 30rpx 0;
  }
  
  .article-title {
    font-size: 36rpx;
  }
  
  .markdown-content {
    font-size: 28rpx;
    line-height: 1.7;
  }
  
  .fab-container {
    right: 30rpx;
    bottom: 30rpx;
  }
  
  .fab-primary, .fab-secondary {
    width: 96rpx;
    height: 96rpx;
  }
  
  .fab-primary .fab-icon {
    font-size: 32rpx;
  }
  
  .fab-secondary .fab-icon {
    font-size: 28rpx;
  }
}
