<!-- 详情页面 -->
<view class="page-container">
  <!-- 错误状态 -->
  <view wx:if="{{hasError}}" class="error-container">
    <text class="error-icon">⚠</text>
    <text class="error-text">{{errorMessage}}</text>
    <view class="retry-button" bindtap="reloadContent">重试</view>
  </view>

  <!-- 内容显示 -->
  <scroll-view wx:else class="content-container" scroll-y="true" enhanced="true" show-scrollbar="false">
    <view class="article-header">
      <text class="article-title">{{title}}</text>
      <view class="article-meta">
        <text class="meta-item">{{formatTime}}</text>
        <text class="meta-item">{{wordCount}}字</text>
        <text wx:if="{{lastModified}}" class="meta-item">更新于 {{lastModified}}</text>
      </view>
      <view class="article-path" bindtap="sharePath">
        <text class="path-icon">📄</text>
        <text class="path-text">{{filePath}}</text>
      </view>
    </view>
    
    <!-- Markdown内容 -->
    <view class="markdown-content">
      <text class="markdown-text">{{markdownContent}}</text>
    </view>
  </scroll-view>

  <!-- 浮动操作按钮组 -->
  <view class="fab-container">
    <view class="fab-secondary" bindtap="copyContent">
      <text class="fab-icon">📋</text>
    </view>
    <view class="fab-primary" bindtap="toggleFocus">
      <text class="fab-icon">{{isFocused ? '★' : '☆'}}</text>
    </view>
  </view>
</view>
