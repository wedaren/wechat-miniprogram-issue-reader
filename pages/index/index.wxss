/* 主页面样式 */
.page-container {
  height: 100vh;
  background-color: #f8f9fa;
}

/* 头部 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 40rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #e9ecef;
}

.tab-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #212529;
}

.refresh-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: #f8f9fa;
}

.icon-refresh {
  font-size: 32rpx;
  color: #6c757d;
  transition: transform 0.3s ease;
}

.icon-refresh.rotating {
  animation: rotate 1s linear infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 树形容器 */
.tree-container {
  flex: 1;
  height: calc(100vh - 120rpx);
  background-color: #ffffff;
}

.tree-item {
  border-bottom: 1rpx solid #f8f9fa;
}

/* 列表项样式 */
.list-item {
  display: flex;
  align-items: center;
  padding: 30rpx 40rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f8f9fa;
  transition: background-color 0.2s ease;
}

.list-item:active {
  background-color: #f8f9fa;
}

.list-item-icon {
  font-size: 32rpx;
  margin-right: 24rpx;
  width: 40rpx;
  text-align: center;
}

.list-item-content {
  flex: 1;
  min-width: 0;
}

.list-item-title {
  font-size: 32rpx;
  color: #212529;
  font-weight: 500;
  line-height: 1.4;
  word-break: break-all;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.list-item-time {
  font-size: 24rpx;
  color: #6c757d;
  margin-top: 8rpx;
}

.list-item-arrow {
  font-size: 32rpx;
  color: #adb5bd;
  margin-left: 20rpx;
}

/* 状态页面样式继承全局样式 */
