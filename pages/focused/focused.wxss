/* 关注问题页面样式 */
@import "../index/index.wxss";

.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 400rpx;
  color: #999999;
  padding: 0 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  color: #ffc107;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 12rpx;
  color: #6c757d;
}

.empty-desc {
  font-size: 24rpx;
  color: #adb5bd;
  text-align: center;
  line-height: 1.4;
}

.list-item-path {
  font-size: 22rpx;
  color: #adb5bd;
  margin-top: 6rpx;
}
