/* 调试页面样式 */
.page-container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.debug-header {
  text-align: center;
  margin-bottom: 40rpx;
  padding: 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 20rpx;
}

.debug-title {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.debug-subtitle {
  font-size: 24rpx;
  opacity: 0.8;
}

.debug-section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  display: block;
}

.status-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.status-item:last-child {
  border-bottom: none;
}

.status-label {
  font-size: 28rpx;
  color: #666;
}

.status-value {
  font-size: 28rpx;
  font-weight: 500;
}

.status-online {
  color: #52c41a;
}

.status-offline {
  color: #ff4d4f;
}

.status-error {
  color: #ff4d4f;
}

.sync-status-idle {
  color: #1890ff;
}

.sync-status-syncing {
  color: #fa8c16;
}

.sync-status-completed {
  color: #52c41a;
}

.sync-status-failed {
  color: #ff4d4f;
}

.button-group {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.debug-button {
  background: #f0f2f5;
  color: #333;
  border: 1rpx solid #d9d9d9;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  transition: all 0.3s;
}

.debug-button.primary {
  background: #1890ff;
  color: white;
  border-color: #1890ff;
}

.debug-button:active {
  transform: scale(0.98);
}

.log-container {
  max-height: 400rpx;
  border: 1rpx solid #f0f0f0;
  border-radius: 12rpx;
  background: #fafafa;
}

.log-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 24rpx;
}

.log-item:last-child {
  border-bottom: none;
}

.log-time {
  color: #999;
  margin-right: 20rpx;
  min-width: 120rpx;
  font-family: monospace;
}

.log-message {
  flex: 1;
  word-break: break-all;
}

.log-info .log-message {
  color: #1890ff;
}

.log-success .log-message {
  color: #52c41a;
}

.log-error .log-message {
  color: #ff4d4f;
}

.log-warning .log-message {
  color: #fa8c16;
}

.log-empty {
  text-align: center;
  color: #999;
  padding: 40rpx;
}

.sync-info {
  background: #f6ffed;
  border: 1rpx solid #b7eb8f;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 20rpx;
}
